---
//@ts-nocheck 
import Layout from '../layouts/Layout.astro';
import Pcard from "../components/p-card.astro";

const endpoint =
  "https://majobbnhdeqzlgfmufao.supabase.co/rest/v1/final-beerlist?select=*";

const options = {
  headers: {
    apikey: "sb_publishable_YFsAaTZu3QhYeyu5exnqCg_x9eNbtkN",
  },
};

const data = await fetch(endpoint, options).then((res) => res.json());
---

<Layout>
   
<div class="bg">
    <img src="/png/langarm.png" alt="baggrund">
</div>
  <main>
    <section class="hero">
<img src="/hero/hero.png" alt="hero">
    </section>
 
<section class="info">
<img class="info-img" src="/png/mand.png" alt="info">
<div class="info-text">
<p><span class="info-title">A Good Case</span> er en dansk virksomhed, der opkøber og videresælger specialøl, som ellers risikerer at blive smidt ud – typisk fordi de nærmer sig bedst før-datoen eller har mindre fejl. 
Virksomheden fungerer som et bindeled mellem bryggerier og forbrugere og har et stærkt fokus på bæredygtighed og reduktion af madspild. Samtidig tilbyder de løsninger til virksomheder, såsom levering af øl til events, fredagsbarer og firmafester samt opsætning af selvbetjeningskøleskabe med øl.</p>
</div>
</section>

<section class="nyheder">
  <h2>NYHEDER</h2>
  <span></span>

  <div class="related-container">
    <div class="related-grid">
      {data
        .slice(0, 4) // 👉 de 4 første = "nyheder"
        .map((item) => (
          <Pcard product={item} />
      ))}
    </div>
  </div>

  <a class="btn" href="/products">SE ALLE NYHEDER</a>
</section>

<div class="info-bar">
    <img src="/png/info.png" alt="info">
</div>

<section class="mest-solgte">
  <h2>MEST SOLGTE</h2>
  <span></span>

  <div class="related-container">
    <div class="related-grid">
      {data
        .slice(4, 8) // 👉 næste 4 (fake "mest solgte")
        .map((item) => (
          <Pcard product={item} />
      ))}
    </div>
  </div>

  <a class="btn" href="/products">SE ALLE MEST SOLGTE</a>
</section>

<section class="info-lagersalg">
    <img class="info-img2" src="/png/ol.png" alt="lager">
    <div class="info-text2">
<p><span class="info-title">A Good Case</span> afholder et fysisk lagersalg, hvor de hver uge sælger et skiftende udvalg af specialøl til lave priser. Her kan kunder finde både kendte og unikke øl – også produkter, som ikke er tilgængelige online. Sortimentet varierer løbende, fordi øllene er opkøbt for at blive reddet før “best before”-datoen, hvilket betyder, at der altid er nye varer at gå på opdagelse i.
Lagersalget fungerer som en mulighed for at gøre et godt køb, da de tilbyder skarpe tilbud og smagekasser til markedets bedste priser, samtidig med at man støtter en bæredygtig idé om at reducere spild af kvalitetsøl.</p>
</div>
</section>
</main>
</Layout>

<style>
   

    .bg {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        z-index: -1;
        pointer-events: none;
    }

    .bg img {
        width: 100%;
        height: auto;
        display: block;
        width: 100%;
        opacity: 0.6;
        align-items: center;
    
    }

    .hero {
        position: relative;
        padding-bottom: 10px;
          margin-top: 500px;
    }

    .hero::after {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        height: 15px;
        background: linear-gradient(to bottom, #468969 0 50%, #3B7057 50% 100%);
    }

    .hero img {
        width: 100%;
           height: 100%;
        display: block;
    }

    .info {
        display: flex;
        align-items: stretch;
        gap: 0;
        margin-top: 200px;
    }

    .info-img {
        width: min(100%, 420px);
        height: auto;
        flex: 0 0 auto;
        
    }

    .info-text {
        flex: 1;
        font-size: 19px;
        font-weight: 300;
        line-height: 150%;
    }

    .info-text,
    .info-text2 {
        background-color: #ffffff;
        padding: 65px;
        box-sizing: border-box;
        display: flex;
        align-items: center;
    }

    .info-title {
        color: #3B7057;
        font-size: 22px;
        font-weight: 300;
    }

    .nyheder h2 {
        display: flex;
        font-size: 35px;
        text-decoration: underline;
        font-weight: 100;
        color: #3B7057;
        margin-top: 200px;
        justify-content: center;
    }

    .nyheder {
        text-align: center;
    }

    .nyheder .btn {
        display: inline-block;
        margin-top: 20px;
        padding: 10px 20px;
        background-color: #ffffff;
        color: #3B7057;
        text-decoration: none;
        border: #3B7057 solid 2px;
        border-radius: 10px;
        font-weight: 300;
    }

      .nyheder .btn:hover {
        background-color: #3B7057;
        color: #ffffff;
      }

    .info-bar {
        margin-top: 200px;
        text-align: center;
    }

    .info-bar img {
        width: 100%;
        height: auto;
        display: block;
    }

    .mest-solgte h2 {
        display: flex;
      font-size: 35px;
        text-decoration: underline;
        font-weight: 100;
        color: #3B7057;
        margin-top: 200px;
        justify-content: center;
    }

    .mest-solgte {
        text-align: center;
    }

    .mest-solgte .btn {
        display: inline-block;
        margin-top: 20px;
        padding: 10px 20px;
        background-color: #ffffff;
        color: #3B7057;
        text-decoration: none;
        border: #3B7057 solid 2px;
        border-radius: 10px;
        font-weight: 300;
    }

      .mest-solgte .btn:hover {
        background-color: #3B7057;
        color: #ffffff;
      }

    .info-lagersalg {
        display: flex;
        flex-direction: row-reverse;
        align-items: stretch;
        gap: 0;
        margin-top: 200px;
    }

    .info-img2 {
        width: min(100%, 420px);
        height: auto;
        flex: 0 0 auto;
    }

    .info-text2 {
        flex: 1;
        font-size: 19px;
        font-weight: 300;
        line-height: 150%;
    }

    @media (max-width: 700px) {
        .info,
        .info-lagersalg {
            flex-direction: column;
            align-items: stretch;
        }

    }
     
    /* ---- Desktop---- */
@media (min-width: 1200px) {
 
       .hero {
        position: relative;
        padding-bottom: 10px;
        margin-top: 1px;
    }
    .hero img {
           height: 70vh;
    }
      .info-title {
        font-size: 32px;
    }
         .info-text2, .info-text {
        font-size: 20px;
    }
        .mest-solgte h2, .nyheder h2 {
        font-size: 42px;
    }
    
}
@media (min-width: 768px) and (max-width: 1199px) {

  /* ----- NYHEDER og MEST-SOLGTE SEKTION ----- */

}
.related-container {
  max-width: 1200px;  
  margin: 40px auto;
  padding: 0 17px;
}

.related-grid {
  display: grid;
  grid-template-columns: 1fr; 
  gap: 1.5rem;
  justify-items: center;
}

/* desktop */
@media (min-width: 1200px) {
  .related-grid {
    grid-template-columns: repeat(4, 340px);
    justify-content: center;
  }
}

/* tablet */
@media (min-width: 768px) and (max-width: 1199px) {
  .related-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
</style>
<script>
      /* ----- gør så på mobil kun bliver vist 1 card, tablet= 2, desktop = 4 ----- */
const grids = document.querySelectorAll(".related-grid");

grids.forEach((grid) => {
  const cards = grid.querySelectorAll<HTMLElement>(":scope > *");

  cards.forEach((card, index) => {
    if (window.innerWidth < 768) {
      card.style.display = index < 1 ? "block" : "none";
    } else if (window.innerWidth < 1200) {
      card.style.display = index < 2 ? "block" : "none";
    } else {
      card.style.display = "block";
    }
  });
});

</script>