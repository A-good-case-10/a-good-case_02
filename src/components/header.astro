<!DOCTYPE html>
<html lang="da">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>A Good Case Header</title>
    <link rel="stylesheet" href="header.css">
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <nav class="site-nav" aria-label="Primær navigation">
          <ul class="site-nav__links site-nav__links--left">
            <li><a class="site-nav__link" href="#">Nyheder</a></li>
            <li><a class="site-nav__link" href="#">Øl</a></li>
          </ul>

          <a class="site-header__brand" href="#" aria-label="A Good Case forside">
            <img src="bilag/LOGO.svg" alt="A Good Case logo">
          </a>

          <ul class="site-nav__links site-nav__links--right">
            <li><a class="site-nav__link" href="#">Smagskasser</a></li>
            <li><a class="site-nav__link" href="#">Tilbud</a></li>
            <li><a class="site-nav__link" href="#">Om os</a></li>
          </ul>
        </nav>

        <div class="site-header__actions">
          <svg class="site-header__icon-strip" viewBox="0 0 180 36" role="img" aria-label="Søg, min konto og kurv">
            <a class="site-header__icon-link" href="#" aria-label="Søg">
              <rect class="site-header__icon-hitbox" x="0" y="0" width="42" height="36" />
              <g transform="translate(0 3)">
                <circle cx="14" cy="14" r="9" fill="none" stroke="currentColor" stroke-width="2.2" />
                <path d="M20.5 20.5L29 29" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2.2" />
              </g>
            </a>

            <a class="site-header__icon-link" href="#" aria-label="Min konto">
              <rect class="site-header__icon-hitbox" x="69" y="0" width="42" height="36" />
              <g transform="translate(69 1)">
                <circle cx="18" cy="9" r="5.5" fill="currentColor" />
                <path d="M4 28C4.9 21.8 9.7 18.8 18 18.8C26.3 18.8 31.1 21.8 32 28H4Z" fill="currentColor" />
              </g>
            </a>

            <a class="site-header__icon-link" href="#" aria-label="Kurv">
              <rect class="site-header__icon-hitbox" x="138" y="0" width="42" height="36" />
              <g transform="translate(138 1)">
                <path d="M4 11H31L28.5 29H6.5L4 11Z" fill="currentColor" />
                <path d="M9 11L17.5 3L26 11" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" />
                <path d="M12 17V23" fill="none" stroke="#FFFFFF" stroke-linecap="round" stroke-width="1.8" />
                <path d="M17.5 17V23" fill="none" stroke="#FFFFFF" stroke-linecap="round" stroke-width="1.8" />
                <path d="M23 17V23" fill="none" stroke="#FFFFFF" stroke-linecap="round" stroke-width="1.8" />
              </g>
            </a>
          </svg>
        </div>
      </div>
    </header>
  </body>
</html>

<style>
html,
body {
  margin: 0;
  padding: 0;
  background: #eef2ef;
}

body {
  min-height: 100vh;
  padding: clamp(16px, 3vw, 40px);
  box-sizing: border-box;
}

*,
*::before,
*::after {
  box-sizing: inherit;
}

.site-header {
  --header-padding-x: clamp(24px, 5vw, 96px);
  --header-gap: clamp(32px, 4vw, 120px);
  --nav-gap: clamp(24px, 2vw, 46px);
  --text-size: clamp(1rem, 1.6vw, 2rem);
  --logo-width: clamp(108px, 10vw, 157px);
  --offset-top: clamp(62px, 5.5vw, 92px);
  background: #ffffff;
  color: #111111;
  font-family: "Futura PT", "Avenir Next", "Helvetica Neue", sans-serif;
  width: 100%;
  max-width: 1900px;
  margin: 0 auto;
  border: 1px solid rgba(17, 17, 17, 0.08);
  border-radius: 28px;
  box-shadow: 0 20px 50px rgba(17, 17, 17, 0.08);
  overflow: hidden;
}

.site-header__inner {
  max-width: 1920px;
  margin: 0 auto;
  padding: 0 var(--header-padding-x) 28px;
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: start;
  column-gap: var(--header-gap);
}

.site-nav {
  display: flex;
  align-items: start;
  gap: clamp(28px, 2.3vw, 52px);
  min-width: 0;
}

.site-nav__links {
  margin: var(--offset-top) 0 0;
  padding: 0;
  list-style: none;
  display: flex;
  align-items: center;
  gap: var(--nav-gap);
}

.site-nav__links--right {
  flex-wrap: wrap;
}

.site-nav__link {
  display: inline-block;
  color: inherit;
  font-size: var(--text-size);
  font-weight: 400;
  line-height: 1;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  text-decoration: none;
  white-space: nowrap;
  transition: opacity 0.2s ease;
}

.site-nav__link:hover,
.site-nav__link:focus-visible {
  opacity: 0.65;
}

.site-header__brand {
  display: inline-flex;
  flex: 0 0 auto;
}

.site-header__brand img {
  display: block;
  width: var(--logo-width);
  height: auto;
}

.site-header__actions {
  margin-top: calc(var(--offset-top) - 2px);
  display: flex;
  align-items: center;
  align-self: start;
}

.site-header__icon-strip {
  width: clamp(136px, 14vw, 190px);
  height: auto;
  display: block;
  color: #111111;
}

.site-header__icon-link {
  color: #111111;
  transition: opacity 0.2s ease;
}

.site-header__icon-link:hover,
.site-header__icon-link:focus-visible {
  opacity: 0.65;
}

.site-header__icon-hitbox {
  fill: transparent;
}

.site-nav__link:focus-visible {
  outline: 2px solid #111111;
  outline-offset: 4px;
}

@media (max-width: 1200px) {
  .site-header {
    --header-gap: 48px;
    --nav-gap: 20px;
    --offset-top: 42px;
    --text-size: clamp(0.95rem, 1.8vw, 1.35rem);
  }

  .site-header__icon-strip {
    width: clamp(126px, 16vw, 168px);
  }
}

@media (max-width: 920px) {
  .site-header__inner {
    grid-template-columns: 1fr;
    row-gap: 18px;
    justify-items: center;
  }

  .site-nav {
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }

  .site-nav__links {
    margin: 0;
    justify-content: center;
    flex-wrap: wrap;
    row-gap: 14px;
  }

  .site-header__brand {
    order: -1;
  }

  .site-header__actions {
    margin-top: 0;
    justify-content: center;
  }
}

@media (max-width: 560px) {
  body {
    padding: 12px;
  }

  .site-header {
    --header-padding-x: 18px;
    --text-size: 0.92rem;
    border-radius: 20px;
  }

  .site-header__inner {
    padding-bottom: 20px;
  }

  .site-nav {
    gap: 18px;
  }

  .site-nav__links {
    gap: 12px 18px;
  }

  .site-header__icon-strip {
    width: 138px;
  }
}
</style>
